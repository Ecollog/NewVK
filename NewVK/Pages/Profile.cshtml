@page
@model NewVK.Pages.ProfileModel
@{
    ViewData["Title"] = "Профиль";
}

<div class="auth-wrap">
    <div class="auth-card">
        <h1 class="auth-title">Профиль</h1>

        <div class="field">
            <label>Логин</label>
            <input value="@Model.Login" readonly />
        </div>

        <div class="grid">
            <div class="field">
                <label>Имя</label>
                <input value="@Model.FirstName" readonly />
            </div>

            <div class="field">
                <label>Фамилия</label>
                <input value="@Model.LastName" readonly />
            </div>
        </div>

        <div class="field">
            <label>Email</label>
            <input value="@Model.Email" readonly />
        </div>

        <div class="field">
            <label>Телефон</label>
            <input value="@Model.Phone" readonly />
        </div>

        <form method="post" asp-page-handler="Logout">
            <button class="btn" type="submit">Выйти</button>
        </form>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
}