@page
@model NewVK.Pages.EditProfileModel
@{
    ViewData["Title"] = "Настройки профиля";

    var currentTheme = Model.Themes.FirstOrDefault(x => x.Key == Model.Input.ThemeKey)
                       ?? Model.Themes.FirstOrDefault();

    var previewName = currentTheme?.Name ?? "Тема";
}

<div class="page-shell edit-page">
    <section class="page-header">
        <div>
            <div class="page-eyebrow">Настройки</div>
            <h1 class="page-title">Редактирование профиля</h1>
            <p class="page-subtitle">
                Все изменения профиля собраны в одном месте: личные данные, описание и тема сайта.
            </p>
        </div>

        <div class="page-actions">
            <span class="header-badge">@previewName</span>
        </div>
    </section>

    <div class="edit-layout">
        <aside class="edit-sidebar">
            <div class="surface-card">
                <h2 class="card-title">Предпросмотр темы</h2>

                <div class="theme-preview">
                    <div class="theme-preview-name" id="theme-preview-name">@previewName</div>

                    <div class="theme-swatches">
                        <span class="swatch swatch-primary" title="Primary"></span>
                        <span class="swatch swatch-sand" title="Sand"></span>
                        <span class="swatch swatch-sage" title="Sage"></span>
                        <span class="swatch swatch-bg" title="Background"></span>
                        <span class="swatch swatch-text" title="Text"></span>
                    </div>

                    <p class="card-text">
                        После выбора тема применяется сразу визуально, а после сохранения закрепляется за аккаунтом.
                    </p>
                </div>
            </div>

            <div class="surface-card">
                <h2 class="card-title">Подсказка</h2>
                <p class="card-text">
                    Логин, контакты и блок «О себе» лучше хранить в актуальном состоянии, чтобы профиль выглядел завершённым.
                </p>
            </div>
        </aside>

        <section class="edit-main-column">
            <div class="surface-card">
                <h2 class="card-title">Данные профиля</h2>

                @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
                {
                    <div class="alert success">@Model.SuccessMessage</div>
                }

                <div asp-validation-summary="ModelOnly" class="alert error"></div>

                <form method="post" asp-page-handler="Save" novalidate>
                    <div class="form-grid">
                        <div class="field">
                            <label asp-for="Input.Login"></label>
                            <input asp-for="Input.Login" />
                            <span asp-validation-for="Input.Login" class="val"></span>
                        </div>

                        <div class="field">
                            <label asp-for="Input.Email"></label>
                            <input asp-for="Input.Email" />
                            <span asp-validation-for="Input.Email" class="val"></span>
                        </div>

                        <div class="field">
                            <label asp-for="Input.FirstName"></label>
                            <input asp-for="Input.FirstName" />
                            <span asp-validation-for="Input.FirstName" class="val"></span>
                        </div>

                        <div class="field">
                            <label asp-for="Input.LastName"></label>
                            <input asp-for="Input.LastName" />
                            <span asp-validation-for="Input.LastName" class="val"></span>
                        </div>

                        <div class="field field-full">
                            <label asp-for="Input.Phone"></label>
                            <input asp-for="Input.Phone" />
                            <span asp-validation-for="Input.Phone" class="val"></span>
                        </div>

                        <div class="field field-full">
                            <label asp-for="Input.AboutMe"></label>
                            <textarea asp-for="Input.AboutMe" rows="6" placeholder="Кратко расскажите о себе"></textarea>
                            <span asp-validation-for="Input.AboutMe" class="val"></span>
                        </div>

                        <div class="field field-full">
                            <label asp-for="Input.ThemeKey"></label>
                            <select asp-for="Input.ThemeKey" id="theme-select">
                                @foreach (var theme in Model.Themes)
                                {
                                    <option value="@theme.Key">@theme.Name</option>
                                }
                            </select>
                            <span asp-validation-for="Input.ThemeKey" class="val"></span>
                        </div>
                    </div>

                    <div class="form-actions">
                        <button class="btn btn-primary-solid" type="submit">Сохранить изменения</button>
                        <a asp-page="/Profile" class="btn btn-outline">Вернуться в профиль</a>
                    </div>
                </form>
            </div>
        </section>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/edit-profile.css" asp-append-version="true" />
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/edit-profile.js" asp-append-version="true"></script>
}
