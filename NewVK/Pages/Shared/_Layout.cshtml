<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NewVK</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/NewVK.styles.css" asp-append-version="true" />

    @* Подключение дополнительных CSS со страниц *@
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header>
        @* тут можешь добавить навбар *@
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer>
        @* тут можешь добавить футер *@
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @* Подключение дополнительных JS со страниц *@
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>