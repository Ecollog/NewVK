@page
@model NewVK.Pages.MessagesModel
@{
    ViewData["Title"] = "Сообщения";
    var active = Model.ActiveDialog;
    var currentUserLetter = string.IsNullOrWhiteSpace(Model.CurrentUserName)
        ? "U"
        : Model.CurrentUserName.Substring(0, 1).ToUpperInvariant();
}

<div class="page-shell messages-page">
    <section class="page-header">
        <div>
            <div class="page-eyebrow">Коммуникации</div>
            <h1 class="page-title">Сообщения</h1>
            <p class="page-subtitle">
                Список диалогов и окно активной переписки собраны на одной странице,
                а навигация по сайту больше не дублируется внутри раздела.
            </p>
        </div>

        <div class="page-actions">
            <div class="header-user-badge">
                <div class="header-user-avatar">@currentUserLetter</div>
                <div>
                    <div class="header-user-name">@Model.CurrentUserName</div>
                    <div class="header-user-login">@@@Model.CurrentUserLogin</div>
                </div>
            </div>
        </div>
    </section>

    <div class="messages-layout">
        <aside class="dialogs-panel">
            <div class="surface-card">
                <div class="panel-header">
                    <h2 class="card-title">Диалоги</h2>
                    <span class="pill">Всего: @Model.Dialogs.Count</span>
                </div>

                <div class="dialogs-list">
                    @foreach (var dialog in Model.Dialogs)
                    {
                        var isActive = dialog.Id == Model.ActiveChatId;

                        <a asp-page="/Messages"
                           asp-route-chat="@dialog.Id"
                           class="dialog-item @(isActive ? "active" : "")">
                            <div class="dialog-avatar">@dialog.UserName.Substring(0, 1).ToUpperInvariant()</div>

                            <div class="dialog-body">
                                <div class="dialog-top">
                                    <span class="dialog-name">@dialog.UserName</span>
                                    <span class="dialog-time">@dialog.LastTime</span>
                                </div>

                                <div class="dialog-preview">@dialog.Preview</div>
                            </div>

                            @if (dialog.UnreadCount > 0)
                            {
                                <span class="dialog-badge">@dialog.UnreadCount</span>
                            }
                        </a>
                    }
                </div>
            </div>
        </aside>

        <section class="chat-panel">
            <div class="surface-card chat-card">
                @if (active is not null)
                {
                    <div class="chat-header">
                        <div class="chat-user">
                            <div class="chat-user-avatar">@active.UserName.Substring(0, 1).ToUpperInvariant()</div>
                            <div>
                                <div class="chat-user-name">@active.UserName</div>
                                <div class="chat-user-handle">@active.UserHandle</div>
                            </div>
                        </div>
                    </div>

                    <div class="chat-messages">
                        @foreach (var message in active.Messages)
                        {
                            <div class="message-row @(message.IsMine ? "mine" : "other")">
                                <div class="message-bubble">
                                    <div class="message-text">@message.Text</div>
                                    <div class="message-time">@message.Time</div>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="chat-compose">
                        <div class="compose-note">
                            Сейчас это демонстрационный интерфейс сообщений. Следующим шагом сюда можно подключить реальные таблицы диалогов и сообщений.
                        </div>
                    </div>
                }
                else
                {
                    <div class="empty-state">
                        Для отображения переписки пока нет активного диалога.
                    </div>
                }
            </div>
        </section>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/messages.css" asp-append-version="true" />
}
