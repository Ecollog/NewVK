@page
@model NewVK.Pages.MessagesModel
@{
    ViewData["Title"] = "Сообщения";
    var active = Model.ActiveDialog;
    var currentUserLetter = string.IsNullOrWhiteSpace(Model.CurrentUserName)
        ? "U"
        : Model.CurrentUserName.Substring(0, 1).ToUpperInvariant();
}

<div class="page-shell messages-page">
    <section class="page-header">
        <div>
            <div class="page-eyebrow">Коммуникации</div>
            <h1 class="page-title">Сообщения</h1>
            <p class="page-subtitle">
                Страница показывает только реальные диалоги из базы данных. Новое сообщение можно отправить пользователю по его логину.
            </p>
        </div>

        <div class="page-actions">
            <div class="header-user-badge">
                <div class="header-user-avatar">@currentUserLetter</div>
                <div>
                    <div class="header-user-name">@Model.CurrentUserName</div>
                    <div class="header-user-login">@("@"+Model.CurrentUserLogin)</div>
                </div>
            </div>
        </div>
    </section>

    <div class="messages-layout">
        <aside class="dialogs-panel">
            <div class="surface-card">
                <div class="panel-header">
                    <h2 class="card-title">Диалоги</h2>
                    <span class="pill">Всего: @Model.Dialogs.Count</span>
                </div>

                @if (Model.Dialogs.Count == 0)
                {
                    <div class="dialogs-empty">
                        Диалогов пока нет. Отправьте первое сообщение по логину пользователя.
                    </div>
                }
                else
                {
                    <div class="dialogs-list">
                        @foreach (var dialog in Model.Dialogs)
                        {
                            var isActive = dialog.Id == Model.ActiveChatId;

                            <a asp-page="/Messages"
                               asp-route-chat="@dialog.Id"
                               class="dialog-item @(isActive ? "active" : "")">
                                <div class="dialog-avatar">@dialog.UserName.Substring(0, 1).ToUpperInvariant()</div>

                                <div class="dialog-body">
                                    <div class="dialog-top">
                                        <span class="dialog-name">@dialog.UserName</span>
                                        <span class="dialog-time">@dialog.LastTime</span>
                                    </div>

                                    <div class="dialog-preview">@dialog.Preview</div>
                                </div>

                                @if (dialog.UnreadCount > 0)
                                {
                                    <span class="dialog-badge">@dialog.UnreadCount</span>
                                }
                            </a>
                        }
                    </div>
                }
            </div>
        </aside>

        <section class="chat-panel">
            <div class="surface-card chat-card">
                @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
                {
                    <div class="alert success">@Model.SuccessMessage</div>
                }

                @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                {
                    <div class="alert error">@Model.ErrorMessage</div>
                }

                @if (active is not null)
                {
                    <div class="chat-header">
                        <div class="chat-user">
                            <div class="chat-user-avatar">@active.UserName.Substring(0, 1).ToUpperInvariant()</div>
                            <div>
                                <div class="chat-user-name">@active.UserName</div>
                                <div class="chat-user-handle">@active.UserHandle</div>
                            </div>
                        </div>
                    </div>

                    @if (active.Messages.Count == 0)
                    {
                        <div class="empty-state">
                            В этом диалоге пока нет сообщений.
                        </div>
                    }
                    else
                    {
                        <div class="chat-messages">
                            @foreach (var message in active.Messages)
                            {
                                <div class="message-row @(message.IsMine ? "mine" : "other")">
                                    <div class="message-bubble">
                                        <div class="message-text">@message.Text</div>
                                        <div class="message-time">@message.Time</div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                }
                else
                {
                    <div class="empty-state chat-empty">
                        Выберите существующий диалог слева или отправьте первое сообщение по логину пользователя.
                    </div>
                }

                <div class="chat-compose">
                    <form method="post" asp-page-handler="Send" class="compose-form">
                        <div class="compose-grid">
                            <div class="field">
                                <label asp-for="Input.TargetLogin">Логин получателя</label>
                                <input asp-for="Input.TargetLogin" autocomplete="username" placeholder="например, ivan" />
                                <span asp-validation-for="Input.TargetLogin" class="val"></span>
                            </div>

                            <div class="field compose-message-field">
                                <label asp-for="Input.Text">Сообщение</label>
                                <textarea asp-for="Input.Text" rows="4" placeholder="Введите текст сообщения"></textarea>
                                <span asp-validation-for="Input.Text" class="val"></span>
                            </div>
                        </div>

                        <div class="compose-actions">
                            <button class="btn btn-primary-solid" type="submit">Отправить</button>
                        </div>
                    </form>
                </div>
            </div>
        </section>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/messages.css" asp-append-version="true" />
}
